{
  "name": "node-lens-cli",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/cli/src",
  "projectType": "library",
  "tags": [],
  "// targets": "to see all targets run: nx show project node-lens-cli --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": [
        "{projectRoot}/dist"
      ],
      "dependsOn": [
        "^build"
      ],
      "options": {
        "parallel": false,
        "commands": [
          "rm -rf packages/cli/dist",
          "tsc --build packages/cli/tsconfig.lib.json",
          "rsync -a --prune-empty-dirs --include=*/ --include=*.js --exclude=* packages/cli/src/ packages/cli/dist/src/"
        ]
      }
    }
  }
}
